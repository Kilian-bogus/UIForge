{
  "name": "uiforge",
  "private": true,
  "version": "1.0.0",
  "description": "UIForge - Visual JavaScript UI Builder with Code Export",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "cd server && node index.js",
